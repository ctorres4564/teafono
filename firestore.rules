rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // User-scoped patient data
    // Only authenticated users can read/write their own patients
    match /users/{userId}/patients/{patientId} {
      allow read, write: if request.auth.uid == userId;
    }

    // User profile
    // Only authenticated users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Assessments (if organized under user)
    match /users/{userId}/assessments/{assessmentId} {
      allow read, write: if request.auth.uid == userId;
    }

    // System Logs
    match /users/{userId}/logs/{logId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}

